from .coordinator import OverkizDataUpdateCoordinator as OverkizDataUpdateCoordinator
from _typeshed import Incomplete
from homeassistant.exceptions import HomeAssistantError as HomeAssistantError
from pyoverkiz.enums import OverkizCommand as OverkizCommand
from pyoverkiz.models import Command, Device as Device, StateDefinition as StateDefinition
from typing import Any

class OverkizExecutor:
    device_url: Incomplete
    coordinator: Incomplete
    def __init__(self, device_url: str, coordinator: OverkizDataUpdateCoordinator) -> None: ...
    @property
    def device(self) -> Device: ...
    def linked_device(self, index: int) -> Device | None: ...
    def select_definition_state(self, *states: str) -> StateDefinition | None: ...
    async def async_execute_command(self, command_name: str, *args: Any, refresh_afterwards: bool = True) -> None: ...
    async def async_execute_commands(self, commands: list[Command], refresh_afterwards: bool = True) -> None: ...
    async def async_cancel_command(self, commands_to_cancel: list[OverkizCommand]) -> bool: ...
    async def async_cancel_execution(self, exec_id: str) -> None: ...
